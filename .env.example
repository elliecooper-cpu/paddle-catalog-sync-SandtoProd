# Loaded automatically by sync_catalog.py when present (do not commit this file).
PADDLE_SANDBOX_API_KEY=pdl_sdbx_apikey_xxxxxxxx
PADDLE_LIVE_API_KEY=pdl_live_apikey_xxxxxxxx

# Optional — only if you're a Paddle partner and want import_meta support
# PADDLE_PARTNER_ID=ptn_xxxxxxxx

# These are CLI flags, not env vars — examples:
#   python3 sync_catalog.py --diagnose
#   python3 sync_catalog.py --live-checkout-url https://yourdomain.com/checkout
#   python3 sync_catalog.py --webhook-url-map webhook-map.json
